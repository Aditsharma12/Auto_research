# ── LLM (HuggingFace Transformers – 100% local, zero API key) ─────────────
# Model is downloaded once and cached at ~/.cache/huggingface
#
# CPU-friendly model options (change LLM_MODEL to switch):
#
#   TinyLlama/TinyLlama-1.1B-Chat-v1.0   ~600MB  – default, fast on CPU
#   microsoft/Phi-3-mini-4k-instruct      ~2.4GB  – better quality, 8GB+ RAM
#   google/flan-t5-base                   ~250MB  – fastest, seq2seq
#   mistralai/Mistral-7B-Instruct-v0.2    ~15GB   – best quality, needs GPU
LLM_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
LLM_MAX_NEW_TOKENS=512
LLM_TEMPERATURE=0.1
LLM_DEVICE=cpu    # cpu | cuda | mps

# ── Embeddings (sentence-transformers – 100% local) ────────────────────────
# ~90MB download, 384-dim, excellent quality/speed ratio
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384     # must match your chosen embed model

# ── Qdrant ──────────────────────────────────────────────────────────────────
# memory = no setup needed (data lost on restart)
# local  = requires qdrant binary running on QDRANT_URL
QDRANT_MODE=memory
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Web Search & Scraping ───────────────────────────────────────────────────
# Set to false to disable web search and rely on Qdrant/LLM knowledge only
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5
WEB_SCRAPE_MAX_CHARS=3000

# ── App ─────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=*
